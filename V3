2) PER-SENSOR DATA / STATUS REGISTERS bloğunu değiştir

Bu blokta:

ID error

CFG error

TEMP update hepsi artık {rd_msb_r, data_rd_w} ile yapılacak.


Bu bloğun ilgili kısmını komple bununla değiştir:

// =========================================================================
// PER-SENSOR DATA / STATUS REGISTERS
// =========================================================================
always @(posedge clk_i or negedge rst_al_i) begin
    if (!rst_al_i) begin
        for (i_r = 0; i_r < 2; i_r = i_r + 1) begin
            init_done_r[i_r]    <= 1'b0;
            temp_r[i_r]         <= 16'h0000;
            data_valid_r[i_r]   <= 1'b0;
            id_error_r[i_r]     <= 1'b0;
            cfg_error_r[i_r]    <= 1'b0;
            ack_error_r[i_r]    <= 1'b0;
            range_error_r[i_r]  <= 1'b0;
        end
    end
    else begin
        // data_valid is a 1-clock pulse
        data_valid_r[0] <= 1'b0;
        data_valid_r[1] <= 1'b0;

        // Sticky ACK error for active sensor
        if ((busy_prev_r == 1'b1) && (busy_w == 1'b0) && ack_error_w) begin
            if (sensor_sel_r == 1'b0) begin
                ack_error_r[0] <= 1'b1;
            end
            else begin
                ack_error_r[1] <= 1'b1;
            end
        end

        // State-based completion handling
        if ((busy_prev_r == 1'b1) && (busy_w == 1'b0)) begin
            case (state_r)

                // ---------------------------------------------------------
                // Device ID read completed
                // ---------------------------------------------------------
                S_INIT_ID_READ: begin
                    if (busy_cntr_r == 3'd3) begin
                        if (sensor_sel_r == 1'b0) begin
                            id_error_r[0] <= ({rd_msb_r, data_rd_w} != EXPECT_DEVICE_ID);
                        end
                        else begin
                            id_error_r[1] <= ({rd_msb_r, data_rd_w} != EXPECT_DEVICE_ID);
                        end
                    end
                end

                // ---------------------------------------------------------
                // Config readback completed
                // ---------------------------------------------------------
                S_INIT_CFG_READ: begin
                    if (busy_cntr_r == 3'd3) begin
                        if (sensor_sel_r == 1'b0) begin
                            cfg_error_r[0] <= ((({rd_msb_r, data_rd_w}) & CFG_COMPARE_MASK) !=
                                               (CFG_WRITE_VALUE & CFG_COMPARE_MASK));
                            init_done_r[0] <= 1'b1;
                        end
                        else begin
                            cfg_error_r[1] <= ((({rd_msb_r, data_rd_w}) & CFG_COMPARE_MASK) !=
                                               (CFG_WRITE_VALUE & CFG_COMPARE_MASK));
                            init_done_r[1] <= 1'b1;
                        end
                    end
                end

                // ---------------------------------------------------------
                // Temperature read completed
                // data_valid and temp update occur in the same clock
                // ---------------------------------------------------------
                S_TEMP_READ: begin
                    if (busy_cntr_r == 3'd3) begin
                        if ($signed({rd_msb_r, data_rd_w}) >= $signed(TEMP_THRESHOLD_LOW) &&
                            $signed({rd_msb_r, data_rd_w}) <= $signed(TEMP_THRESHOLD_HIGH)) begin

                            if (sensor_sel_r == 1'b0) begin
                                temp_r[0]        <= {rd_msb_r, data_rd_w};
                                data_valid_r[0]  <= 1'b1;
                                range_error_r[0] <= 1'b0;
                            end
                            else begin
                                temp_r[1]        <= {rd_msb_r, data_rd_w};
                                data_valid_r[1]  <= 1'b1;
                                range_error_r[1] <= 1'b0;
                            end
                        end
                        else begin
                            if (sensor_sel_r == 1'b0) begin
                                range_error_r[0] <= 1'b1;
                            end
                            else begin
                                range_error_r[1] <= 1'b1;
                            end
                        end
                    end
                end

                default: begin
                end
            endcase
        end
    end
end


