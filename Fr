localparam [15:0] DAC_06MA = 16'h03D7;   // 983
localparam [15:0] DAC_04MA = 16'h028F;   // 655
localparam [15:0] DAC_02MA = 16'h0148;   // 328
localparam [15:0] DAC_00MA = 16'h0000;   // 0

reg [31:0] toggle_timer_cntr_r;
reg [31:0] step_target_cntr_r;
reg [5:0]  test_step_r;


---

2) Reset kısmı

Resette başlangıç değerini ilk tablo satırı yap:

if (!rst_al_i) begin
    toggle_timer_cntr_r <= 32'd0;
    step_target_cntr_r  <= 10 * ONE_MS_CNTR;
    test_step_r         <= 6'd0;

    fmu_dac_data_test_r <= DAC_20MA;
    fmu_role_test_r     <= 1'b0; // +20 mA
end


---

